# ─────────────────────────────────────────────────────────────
# Mit-Mak Motors — environment variables
# Copy to `.env.local` for local dev. Set the same keys in Vercel.
# Everything has a sensible fallback, so the site runs with none set.
# ─────────────────────────────────────────────────────────────

# Canonical site URL — used for metadata, OpenGraph, sitemap & robots.
NEXT_PUBLIC_SITE_URL=https://mitmakmotors.co.za

# Quick-action contact details (header + floating buttons + footer).
NEXT_PUBLIC_PHONE=+27 12 004 0000
NEXT_PUBLIC_WHATSAPP=27600000000

# Where the multi-step forms POST. Leave blank to use the built-in
# /api/* mock handlers (they log + echo success) during development.
FORM_WEBHOOK_URL=

# Optional: Google Maps Embed API key for the Contact page map.
# Without it, the page renders a styled static map placeholder.
NEXT_PUBLIC_GOOGLE_MAPS_KEY=
